{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "project": "./tsconfig.json"
  },
  "plugins": ["@typescript-eslint"],
  "extends": [
    "airbnb-base",
    "airbnb-typescript/base",
    "plugin:@typescript-eslint/recommended",
    "plugin:@typescript-eslint/recommended-requiring-type-checking"
  ],
  "rules": {
    // Bu yerga Airbnb qoidalarini biroz yumshatish yoki qo'shimcha strict qoidalar qo'shish mumkin
    "@typescript-eslint/no-explicit-any": "error", // 'any' tipidan foydalanishni taqiqlash (Strict)
    "import/extensions": "off" // TypeScript modullari uchun kengaytmalarni majburlamaslik
  }
}
